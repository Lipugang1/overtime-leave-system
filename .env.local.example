# Supabase 配置 - 复制此文件为 .env.local 并填入您的实际值
# 在 Supabase 控制台 Settings > API 中获取这些值

# Supabase 项目URL（Project URL）
COZE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anon Key（anon public key）
COZE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Service Role Key（service_role secret key - 可选但推荐）
COZE_SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# JWT密钥 - 用于用户认证Token签名（可设置任意随机字符串）
JWT_SECRET=your-super-secret-jwt-key-here-change-this

# 可选：S3/对象存储配置（用于手写签名图片存储，暂时可不填）
# S3_ENDPOINT=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET_NAME=
# S3_REGION=
